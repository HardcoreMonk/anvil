# ==========================================
# ephemera - .gitignore
# ==========================================

# 1. Compiled Go binaries
/anvil-daemon
/anvil-mcp
/anvil-scheduler
/ephemera-daemon
/goose-daemon
/cmd/goose-daemon/goose-daemon
*.exe
*.exe~
*.dll
*.so
*.dylib

# 2. Firecracker artifacts & huge files
/artifacts/*
!/artifacts/.keep
*.ext4
*.img
*.bin
*.tgz
vmlinux*

# 3. Unix domain sockets & logs
*.sock
*.log
/tmp/*

# 4. Runtime-generated directories
/snapshots/
/tmp/

# 5. Goose runtime config (contains API keys)
configs/anvil-mcp.yaml
configs/goose.yaml
configs/goose-secrets.yaml
configs/profiles/*/goose.yaml
configs/profiles/*/goose-secrets.yaml

# 6. Claude Code context file
CLAUDE.md
Handoff.md
.superpowers/
EPHEMERA_GOOSETOWN_INTEGRATION.md
EPHEMERA_v0.3.1_WORK_ORDER.md

# 7. OS & Editor generated files
.vscode/
.idea/
.DS_Store
