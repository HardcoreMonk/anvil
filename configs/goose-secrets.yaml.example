# Goose secrets injected into each MicroVM at provisioning time.
# Stored separately from goose.yaml so non-secret config can be reviewed safely.
#
# Usage:
#   cp configs/goose-secrets.yaml.example configs/goose-secrets.yaml
#   # Fill in your API key.
#
# configs/goose-secrets.yaml is gitignored — never commit API keys.

# Google AI Studio: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY: "your-key-here"

# Uncomment the relevant key for other providers:
# ANTHROPIC_API_KEY: "sk-ant-your-key-here"
# OPENAI_API_KEY: "sk-your-key-here"
