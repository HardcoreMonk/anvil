# anvil-mcp 설정.
# 환경 변수는 아래 값을 override한다:
# - ANVIL_DAEMON_URL
# - ANVIL_API_TOKEN
# - ANVIL_MCP_DEFAULT_TIMEOUT
# - ANVIL_MCP_SESSION_STORE
# - ANVIL_MCP_TENANT_ID
# - ANVIL_MCP_AUDIT_LOG

daemon_url: http://127.0.0.1:3000
api_token: ""
default_timeout_seconds: 300

# 선택 사항: session alias 영속 저장소.
# 비워 두거나 생략하면 기존 in-memory-only session 동작을 유지한다.
# 한 file은 single-writer 계약이다. 여러 anvil-mcp process를 동시에 실행한다면
# file locking/catalog 설계가 추가되기 전까지 process마다 다른 path를 사용한다.
# session_store_path: /var/lib/anvil-mcp/sessions.json

# 선택 사항: 향후 multi-tenant scheduler/audit 연동에서 사용할 기본 tenant ID.
# 현재 daemon API contract에는 tenant field를 전달하지 않는다.
# default_tenant_id: tenant.alpha

# 선택 사항: MCP boundary/runtime audit JSONL path.
# append-only record는 tenant ID, VM/session alias, tool name, daemon operation,
# result code, timestamp만 저장하고 agent_token은 저장하지 않는다.
# 이 값을 켜면 tool input tenant_id 또는 default_tenant_id가 필요하다.
# audit_log_path: /var/lib/anvil-mcp/runtime-audit.jsonl
